# =============================================================================
# JavaConnect KE — Spring AI Workshop — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Maven
# -----------------------------------------------------------------------------
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/wrapper/maven-wrapper.properties

# -----------------------------------------------------------------------------
# IntelliJ IDEA
# -----------------------------------------------------------------------------
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# -----------------------------------------------------------------------------
# Eclipse
# -----------------------------------------------------------------------------
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/
*.code-workspace

# -----------------------------------------------------------------------------
# NetBeans
# -----------------------------------------------------------------------------
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# -----------------------------------------------------------------------------
# Spring Boot
# -----------------------------------------------------------------------------
spring-shell.log

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
log/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Docker / Infra local data (never commit volume data)
# -----------------------------------------------------------------------------
infra/grafana/data/
infra/prometheus/data/
infra/tempo/data/
infra/qdrant/data/

# -----------------------------------------------------------------------------
# Environment / Secrets — never commit these
# -----------------------------------------------------------------------------
.env
.env.*
*.key
*.pem
*.p12
*.jks
application-local.yml
application-local.properties
application-secret*.yml
application-secret*.properties

# -----------------------------------------------------------------------------
# Java
# -----------------------------------------------------------------------------
*.class
*.jar
!.mvn/wrapper/maven-wrapper.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# -----------------------------------------------------------------------------
# Test output
# -----------------------------------------------------------------------------
**/surefire-reports/
**/failsafe-reports/
