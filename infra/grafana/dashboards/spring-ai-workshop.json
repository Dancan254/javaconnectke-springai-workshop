{
  "uid": "spring-ai-workshop",
  "title": "Spring AI Workshop — Lab Observability",
  "description": "Monitors all Spring AI workshop labs. Shows AI model latency, token usage, HTTP traffic, and JVM health.",
  "tags": ["spring-ai", "workshop", "ollama"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "schemaVersion": 38,
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "AI Model Performance",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Total AI Requests",
      "description": "Cumulative number of calls made to the local Ollama model since the app started.",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum(gen_ai_client_operation_seconds_count)",
          "legendFormat": "requests"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "AI Request Rate",
      "description": "Number of model calls per minute averaged over the last 2 minutes.",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum(rate(gen_ai_client_operation_seconds_count[2m])) * 60",
          "legendFormat": "req/min"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "P99 AI Latency",
      "description": "99th percentile end-to-end time for a model call (prompt → first token → full response). High values usually mean the model is CPU-bound on the host.",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 15000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(gen_ai_client_operation_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Total Tokens Used",
      "description": "Cumulative input + output tokens consumed across all model calls. Each token is roughly 3–4 characters of text.",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum(gen_ai_client_token_usage_total)",
          "legendFormat": "tokens"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Token Rate",
      "description": "Tokens generated per second averaged over the last 2 minutes. A useful proxy for model throughput.",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum(rate(gen_ai_client_token_usage_total[2m]))",
          "legendFormat": "tokens/s"
        }
      ]
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Error Rate",
      "description": "Percentage of AI model calls that ended in an error (e.g. Ollama timeout, model not loaded).",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",uri=~\"/chat.*\"}[2m])) / sum(rate(http_server_requests_seconds_count{uri=~\"/chat.*\"}[2m]))",
          "legendFormat": "error %"
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "AI Operation Duration — Latency Percentiles",
      "description": "End-to-end latency for model calls broken into P50 (median), P95, and P99. The gap between P50 and P99 shows how variable response times are — a large gap often means occasional slow loads into VRAM.",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gen_ai_client_operation_seconds_bucket[2m]))) * 1000",
          "legendFormat": "P50 (median)"
        },
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gen_ai_client_operation_seconds_bucket[2m]))) * 1000",
          "legendFormat": "P95"
        },
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(gen_ai_client_operation_seconds_bucket[2m]))) * 1000",
          "legendFormat": "P99"
        }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Token Usage — Input vs Output",
      "description": "Tokens consumed per second, split by type. Input tokens (your prompt + memory context) are cheaper to produce than output tokens (the model's generated reply). A high input/output ratio often indicates large memory windows or long system prompts.",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum by (gen_ai_token_type) (rate(gen_ai_client_token_usage_total[2m]))",
          "legendFormat": "{{gen_ai_token_type}} tokens/s"
        }
      ]
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Cumulative Token Usage",
      "description": "Running total of tokens consumed since the app started, by type. Useful for estimating API costs when switching to a cloud provider.",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum by (gen_ai_token_type) (gen_ai_client_token_usage_total)",
          "legendFormat": "{{gen_ai_token_type}}"
        }
      ]
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "AI Requests by Model",
      "description": "Request rate broken down by the model that handled each call. Useful when comparing models side-by-side or after a live model swap.",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_operation_seconds_count[2m])) * 60",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "HTTP API",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "HTTP Request Rate by Endpoint",
      "description": "Requests per minute for each chat endpoint. Compare /chat/simple (stateless) vs /chat/memory (stateful) vs /chat/stream to understand which path is being exercised.",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{uri=~\"/chat.*|/conversations.*\"}[2m])) * 60",
          "legendFormat": "{{uri}}"
        }
      ]
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "HTTP Response Latency — P99 by Endpoint",
      "description": "99th percentile HTTP response time per endpoint. /chat/stream will appear low here because the first chunk is returned quickly — the full response time is in the AI latency panel above.",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "histogram_quantile(0.99, sum by (uri, le) (rate(http_server_requests_seconds_bucket{uri=~\"/chat.*\"}[5m]))) * 1000",
          "legendFormat": "{{uri}} p99"
        }
      ]
    },

    {
      "id": 30,
      "type": "row",
      "title": "JVM Health",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "JVM Heap Memory",
      "description": "Heap memory used vs committed. If used approaches committed, the JVM will GC aggressively. If committed grows unboundedly, you may have a memory leak.",
      "gridPos": { "x": 0, "y": 29, "w": 8, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "used"
        },
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum(jvm_memory_committed_bytes{area=\"heap\"})",
          "legendFormat": "committed"
        }
      ]
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "CPU Usage",
      "description": "Process CPU usage vs total system CPU. High process CPU during model calls is expected — the model runs on the JVM-adjacent Ollama process on the same host.",
      "gridPos": { "x": 8, "y": 29, "w": 8, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "process_cpu_usage",
          "legendFormat": "JVM process"
        },
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "system_cpu_usage",
          "legendFormat": "system"
        }
      ]
    },

    {
      "id": 33,
      "type": "timeseries",
      "title": "GC Pause Duration",
      "description": "Time spent in garbage collection pauses. Spikes here during heavy AI workloads indicate the response object graph is large — consider tuning heap size with -Xmx.",
      "gridPos": { "x": 16, "y": 29, "w": 8, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "workshop-prometheus" },
          "expr": "sum by (cause) (rate(jvm_gc_pause_seconds_sum[2m])) * 1000",
          "legendFormat": "{{cause}}"
        }
      ]
    }
  ]
}
